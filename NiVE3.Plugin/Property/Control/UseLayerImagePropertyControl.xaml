<local:PropertyControlBase x:Class="NiVE3.Plugin.Property.Control.UseLayerImagePropertyControl"
                           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                           xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                           xmlns:upr="clr-namespace:NiVE3.UI.Primitive;assembly=NiVE3.UI"
                           xmlns:ucv="clr-namespace:NiVE3.UI.Converter;assembly=NiVE3.UI"
                           xmlns:ur="clr-namespace:NiVE3.UI.Resources;assembly=NiVE3.UI"
                           xmlns:cv="clr-namespace:NiVE3.Plugin.Property.Control.Converter"
                           xmlns:r="clr-namespace:NiVE3.Plugin.Internal.View.Resources"
                           xmlns:vo="clr-namespace:NiVE3.Plugin.ValueObject"
                           xmlns:local="clr-namespace:NiVE3.Plugin.Property.Control"
                           mc:Ignorable="d" 
                           x:Name="Root"
                           DataContextChanged="Root_DataContextChanged"
                           d:DesignHeight="450" d:DesignWidth="800">
    <local:PropertyControlBase.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <r:LanguageResourceDictionary />
            </ResourceDictionary.MergedDictionaries>

            <ucv:EnumToBoolConverter x:Key="EnumToBoolConverter" UseAndCompare="True"/>
            <ucv:EqualMultiValueConverter x:Key="EqualMultiValueConverter"/>
            <ucv:BooleanInvertConverter x:Key="BooleanInvertConverter"/>
            <cv:CollectionIndexConverter x:Key="CollectionIndexConverter" Offset="1"/>
            <cv:EnumToLocalizedNameConverter x:Key="EnumToLocalizedNameConverter" EnumType="{x:Type vo:LayerImageProcessType}" LanguageResourceDictionaryType="{x:Type r:LanguageResourceDictionary}"/>
            <cv:EnumTypeToArrayConverter x:Key="EnumTypeToArrayConverter" FilterNeverEditorBrowsable="True"/>

            <CollectionViewSource x:Key="LayerCollectionViewSource" Source="{Binding Source={x:Reference Root}, Path=LayerCollectionSource}"/>
            <CompositeCollection x:Key="LayerCollection">
                <x:Null />
                <upr:ContextMenuSelectBoxSeparator />
                <CollectionContainer Collection="{Binding Source={StaticResource LayerCollectionViewSource}}"/>
            </CompositeCollection>

            <!-- NOTE: INotifyCollectionChangeの変更はBindingでは拾ってくれないため、無理矢理拾わせるためのクラスでラップする -->
            <ur:CollectionChangeNotifier x:Key="LayerCollectionNotifier" Collection="{Binding Source={x:Reference Root}, Path=LayerCollectionSource}"/>

            <Style x:Key="LayerSelectBoxStyle" TargetType="{x:Type upr:ContextMenuSelectBox}" BasedOn="{StaticResource {x:Type upr:ContextMenuSelectBox}}">
                <Setter Property="Margin" Value="5,2,0,2"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="{x:Type MenuItem}">
                            <Setter Property="IsChecked" Value="False"/>
                            <Setter Property="IsEnabled" Value="True"/>

                            <Style.Triggers>
                                <DataTrigger Value="True">
                                    <DataTrigger.Binding>
                                        <MultiBinding Converter="{StaticResource EqualMultiValueConverter}">
                                            <Binding Path="DataContext" RelativeSource="{RelativeSource Self}"/>
                                            <Binding Path="PlacementTarget.SelectedItem" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type ContextMenu}}"/>
                                        </MultiBinding>
                                    </DataTrigger.Binding>
                                    <Setter Property="IsChecked" Value="True"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SourceType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static local:UseLayerImagePropertyControl.ImageSourceType}}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Setter.Value>
                </Setter>
                <Setter Property="ItemTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <TextBlock x:Name="LayerName">
                                <TextBlock.Tag>
                                    <MultiBinding Converter="{StaticResource CollectionIndexConverter}">
                                        <Binding Path="Collection" Source="{StaticResource LayerCollectionNotifier}"/>
                                        <Binding />
                                        <!-- NOTE: INotifyCollectionChange通知用 -->
                                        <Binding Path="Update" Source="{StaticResource LayerCollectionNotifier}"/>
                                    </MultiBinding>
                                </TextBlock.Tag>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}: {1}">
                                        <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                                        <Binding Path="Name"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <DataTemplate.Triggers>
                                <Trigger Property="DataContext" Value="{x:Null}">
                                    <Setter TargetName="LayerName" Property="Text" Value="{DynamicResource {x:Static r:LanguageResourceDictionary.PropertyControl_UseLayerImagePropertyControl_None}}"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ImageProcessTypeSelectBoxStyle" TargetType="{x:Type upr:ContextMenuSelectBox}" BasedOn="{StaticResource {x:Type upr:ContextMenuSelectBox}}">
                <Setter Property="Margin" Value="5,2,0,2"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Width" Value="100"/>
                <Setter Property="ItemTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumToLocalizedNameConverter}}"/>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </local:PropertyControlBase.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <upr:ContextMenuSelectBox Grid.Column="0"
                                  Width="{Binding Property.SelectBoxWidth}"
                                  SelectedItem="{Binding ElementName=Root, Path=SelectedLayer}"
                                  ItemsSource="{StaticResource LayerCollection}"
                                  IsEnabled="{Binding ParentLayerIsLock, Converter={StaticResource BooleanInvertConverter}}"
                                  Style="{StaticResource LayerSelectBoxStyle}"
                                  SelectItemChangedByUser="LayerSelectBox_SelectItemChangedByUser"/>
        <upr:ContextMenuSelectBox Grid.Column="1"
                                  SelectedItem="{Binding ElementName=Root, Path=SelectedImageProcessType}"
                                  ItemsSource="{Binding Source={x:Type vo:LayerImageProcessType}, Converter={StaticResource EnumTypeToArrayConverter}}"
                                  IsEnabled="{Binding ParentLayerIsLock, Converter={StaticResource BooleanInvertConverter}}"
                                  Style="{StaticResource ImageProcessTypeSelectBoxStyle}"
                                  SelectItemChangedByUser="ImageProcessTypeSelectBox_SelectItemChangedByUser"/>
    </Grid>
</local:PropertyControlBase>
