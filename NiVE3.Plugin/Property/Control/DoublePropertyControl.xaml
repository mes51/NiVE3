<local:PropertyControlBase x:Class="NiVE3.Plugin.Property.Control.DoublePropertyControl"
                           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                           xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                           xmlns:local="clr-namespace:NiVE3.Plugin.Property.Control"
                           xmlns:pr="clr-namespace:NiVE3.UI.Primitive;assembly=NiVE3.UI"
                           xmlns:ucv="clr-namespace:NiVE3.UI.Converter;assembly=NiVE3.UI"
                           xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                           mc:Ignorable="d" 
                           x:Name="Root"
                           d:DesignHeight="450" d:DesignWidth="800">
    <local:PropertyControlBase.Resources>
        <ucv:BooleanInvertConverter x:Key="BooleanInvertConverter"/>
    </local:PropertyControlBase.Resources>
    <Grid Margin="5,0">
        <pr:SlidableNumberTextBox Value="{Binding CurrentTimeRawValue}"
                                  DisplayValue="{Binding CurrentTimeValue}"
                                  ShowDisplayValue="{Binding IsEnableExpression}"
                                  Maximum="{Binding Property.MaxValue}"
                                  Minimum="{Binding Property.MinValue}"
                                  SlideChangeValue="{Binding Property.SlideChangeValue}"
                                  Digit="{Binding Property.Digit}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"
                                  MinWidth="25"
                                  IsEnabled="{Binding ParentLayerIsLock, Converter={StaticResource BooleanInvertConverter}}"
                                  UnitText="{Binding ElementName=Root, Path=Unit}"
                                  BeginSlideEditValue="SlidableNumberTextBox_BeginEditValue"
                                  EndSlideEditValue="SlidableNumberTextBox_EndEditValue"
                                  AbortSlideEditValue="SlidableNumberTextBox_AbortEditValue"
                                  BeginTextEditValue="SlidableNumberTextBox_BeginEditValue"
                                  EndTextEditValue="SlidableNumberTextBox_EndEditValue"
                                  AbortTextEditValue="SlidableNumberTextBox_AbortEditValue"/>
    </Grid>
</local:PropertyControlBase>
