<local:PropertyControlBase x:Class="NiVE3.Plugin.Property.Control.CheckBoxPropertyControl"
                           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                           xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                           xmlns:local="clr-namespace:NiVE3.Plugin.Property.Control"
                           mc:Ignorable="d" 
                           x:Name="Root"
                           d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <CheckBox Margin="5,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsChecked="{Binding CurrentTimeRawValue, Mode=OneWay}" Command="{Binding ElementName=Root, Path=ChangeCheckedCommand}"/>
    </Grid>
</local:PropertyControlBase>
