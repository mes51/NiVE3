<Window x:Class="NiVE3.Windows.UnhandledExceptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NiVE3.Windows"
        xmlns:gm="clr-namespace:NiVE3.View.Resource.Wpf.GeneratedMarkup"
        mc:Ignorable="d"
        x:Name="Root"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Title="{gm:LanguageResource ResourceKey=UnhandledExceptionWindow_Title}"
        Height="450" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Margin="10" Width="{x:Static local:UnhandledExceptionWindow.IconSize}" Height="{x:Static local:UnhandledExceptionWindow.IconSize}" Source="{x:Static local:UnhandledExceptionWindow.ErrorIcon}"/>
            <TextBlock Grid.Column="1" Text="{gm:LanguageResource ResourceKey=UnhandledExceptionWindow_Message}" VerticalAlignment="Center"/>
        </Grid>

        <TextBlock Grid.Row="1" Margin="10" Text="{gm:LanguageResource ResourceKey=UnhandledExceptionWindow_ExceptionInfo}"/>

        <TextBox Grid.Row="2" Margin="10,0" Text="{Binding ElementName=Root, Path=ExceptionInfo, Mode=OneWay}" IsReadOnly="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>

        <Button Grid.Row="3" Margin="10" HorizontalAlignment="Right" Content="{gm:LanguageResource ResourceKey=Dialog_OK}" Command="{Binding ElementName=Root, Path=CloseButton}" IsDefault="True"/>
    </Grid>
</Window>
