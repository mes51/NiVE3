<UserControl x:Class="NiVE3.View.Pane.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:local="clr-namespace:NiVE3.View.Pane"
             xmlns:vm="clr-namespace:NiVE3.ViewModel"
             xmlns:um="clr-namespace:NiVE3.Model.UI"
             xmlns:uvo="clr-namespace:NiVE3.Plugin.ValueObject;assembly=NiVE3.Plugin"
             xmlns:r="clr-namespace:NiVE3.View.Resource"
             xmlns:cv="clr-namespace:NiVE3.View.Converter"
             xmlns:ucv="clr-namespace:NiVE3.UI.Converter;assembly=NiVE3.UI"
             xmlns:pr="clr-namespace:NiVE3.View.Primitive"
             xmlns:pt="clr-namespace:NiVE3.View.Part"
             xmlns:a="clr-namespace:NiVE3.Wpf.Attach"
             xmlns:b="clr-namespace:NiVE3.Wpf.Behavior"
             xmlns:gm="clr-namespace:NiVE3.View.Resource.Wpf.GeneratedMarkup"
             xmlns:ugm="clr-namespace:NiVE3.UI.Resources.Wpf.GeneratedMarkup;assembly=NiVE3.UI"
             xmlns:cgm="clr-namespace:NiVE3.Config.Wpf.GeneratedMarkup"
             mc:Ignorable="d" 
             x:Name="Root"
             DataContextChanged="Root_DataContextChanged"
             PreviewMouseWheel="Root_PreviewMouseWheel"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <cv:IsNullConverter x:Key="IsNullConverter"/>
        <ucv:BooleanInvertConverter x:Key="BooleanInvertConverter"/>
        <cv:TimeToDoubleConverter x:Key="TimeToDoubleConverter" FrameRate="{Binding FrameRate}"/>
        <cv:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" UseAndCompare="True"/>

        <r:BindingProxy x:Key="ViewModelProxy" Data="{Binding}"/>

        <Thickness x:Key="ColumnMargin">2,0,0,0</Thickness>
        <Thickness x:Key="IconMargin">4,0,0,0</Thickness>

        <Style x:Key="HeaderIconPath" TargetType="{x:Type Path}">
            <Setter Property="Fill" Value="{ugm:AppearanceResource ResourceKey=TextBrush, ReturnDynamicResource=True}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="IconContainer" TargetType="{x:Type Grid}">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="{StaticResource IconMargin}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="HeaderIconPanel" TargetType="{x:Type StackPanel}">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="HeaderTextBlock" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="{StaticResource ColumnMargin}"/>
        </Style>

        <Style x:Key="LayerCollectionStyle" TargetType="{x:Type pt:LayerCollectionView}" BasedOn="{x:Static pt:LayerCollectionView.DefaultStyle}">
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ItemContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer}">
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_Shape}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddShapeLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_Camera}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddCameraLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_Light}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddLightLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_NullObject}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddNullObjectLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_Text}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddTextLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                            <Separator />
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_LoadSolid}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddSolidLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                            <Separator />
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_Procedural}" ItemsSource="{Binding Source={StaticResource ViewModelProxy}, Path=Data.ProceduralInputItems}">
                                <MenuItem.ItemTemplate>
                                    <DataTemplate DataType="{x:Type um:ProceduralInputItem}">
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </MenuItem.ItemTemplate>
                                <MenuItem.ItemContainerStyle>
                                    <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                        <Setter Property="Command" Value="{Binding Source={StaticResource ViewModelProxy}, Path=Data.AddProceduralFootageCommand}"/>
                                        <Setter Property="CommandParameter" Value="{Binding}"/>
                                    </Style>
                                </MenuItem.ItemContainerStyle>
                            </MenuItem>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Effect}" ItemsSource="{Binding Source={StaticResource ViewModelProxy}, Path=Data.GroupedEffects}" IsEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}, Path=PlacementTarget.DataContext.IsSpecial, Converter={StaticResource BooleanInvertConverter}}">
                            <MenuItem.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Value}">
                                    <TextBlock Text="{Binding Key}"/>

                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate DataType="{x:Type um:EffectItem}">
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                    <HierarchicalDataTemplate.ItemContainerStyle>
                                        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Command" Value="{Binding Source={StaticResource ViewModelProxy}, Path=Data.AddEffectCommand}"/>
                                            <Setter Property="CommandParameter" Value="{Binding}"/>
                                        </Style>
                                    </HierarchicalDataTemplate.ItemContainerStyle>
                                </HierarchicalDataTemplate>
                            </MenuItem.ItemTemplate>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Mask}" Visibility="{Binding RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}, Path=PlacementTarget.DataContext.SourceType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter={x:Static local:TimelineView.CompositionDisplayableSourceType}}">
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Mask_AddRectangle}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddRectangleMaskGesture}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Mask_AddEllipse}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddEllipseMaskGesture}"/>
                            <Separator />
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Mask_AddBezier}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddBezierMaskGesture}"/>
                        </MenuItem>
                        <Separator Visibility="{Binding RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}, Path=PlacementTarget.DataContext.SourceType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter={x:Static local:TimelineView.CompositionDisplayableSourceType}}"/>
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Cut}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=CutItemGesture}"/>
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Copy}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=CopyItemGesture}"/>
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Paste}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=PasteItemGesture}"/>
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Duplicate}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=DuplicateItemGesture}"/>
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_SplitLayer}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=SplitLayerGesture}"/>
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Delete}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=DeleteItemGesture}"/>
                        <Separator />
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_Time}">
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_MoveSourceStartPointToIndicatorBaseInPoint}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=MoveSourceStartPointToIndicatorBaseInPointGesture}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_MoveSourceStartPointToIndicatorBaseOutPoint}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=MoveSourceStartPointToIndicatorBaseOutPointGesture}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_MoveInPointToIndicator}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=MoveInPointToIndicatorGesture}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_MoveOutPointToIndicator}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=MoveOutPointToIndicatorGesture}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_ShiftSourceStartPointToNextFrame}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=ShiftSourceStartPointToNextFrameGesture}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_ShiftSourceStartPointToPreviousFrame}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=ShiftSourceStartPointToPreviousFrameGesture}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_ShiftSourceStartPointToNext10Frame}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=ShiftSourceStartPointToNext10FrameGesture}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_ShiftSourceStartPointToPrevious10Frame}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=ShiftSourceStartPointToPrevious10FrameGesture}"/>
                            <Separator />
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_ChangePlayRate}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=ChangeLayerPlayRateGesture}"/>
                            <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_ChangeLayerFreezeFrame}" IsChecked="{Binding RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}, Path=PlacementTarget.DataContext.IsFreezeFrame}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=ChangeLayerFreezeFrameGesture}"/>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_MoveLayerOrderUp}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=MoveLayerOrderUpGesture}"/>
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_MoveLayerOrderDown}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=MoveLayerOrderDownGesture}"/>
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_ChangeLayerTagsRandomly}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=ChangeLayerTagsRandomlyGesture}"/>
                        <Separator />
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_LoadEffectOrMaskPreset}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=LoadPresetGesture}" IsEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}, Path=PlacementTarget.DataContext.IsSpecial, Converter={StaticResource BooleanInvertConverter}}"/>
                        <Separator />
                        <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_CompositionSetting}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=OpenCompositionSettingGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ItemsControl}">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Visible" Focusable="True" FocusVisualStyle="{x:Null}" IsTabStop="False">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CompositionModel, Converter={StaticResource IsNullConverter}, ConverterParameter=True}" Value="True">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer}">
                                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_Shape}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddShapeLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_Camera}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddCameraLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_Light}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddLightLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_NullObject}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddNullObjectLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_Text}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddTextLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                                    <Separator />
                                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_LoadSolid}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=AddSolidLayerGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                                    <Separator />
                                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_AddLayer_Procedural}" ItemsSource="{Binding Source={StaticResource ViewModelProxy}, Path=Data.ProceduralInputItems}">
                                        <MenuItem.ItemTemplate>
                                            <DataTemplate DataType="{x:Type um:ProceduralInputItem}">
                                                <TextBlock Text="{Binding Name}"/>
                                            </DataTemplate>
                                        </MenuItem.ItemTemplate>
                                        <MenuItem.ItemContainerStyle>
                                            <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                <Setter Property="Command" Value="{Binding Source={StaticResource ViewModelProxy}, Path=Data.AddProceduralFootageCommand}"/>
                                                <Setter Property="CommandParameter" Value="{Binding}"/>
                                            </Style>
                                        </MenuItem.ItemContainerStyle>
                                    </MenuItem>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ContextMenu_CompositionSetting}" a:MenuItemGestureBindingProperty.InputBinding="{cgm:ShortcutKeyBinding ResourceKey=OpenCompositionSettingGesture}" CommandTarget="{Binding Source={x:Reference Root}}"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition MinWidth="100"/>
            <ColumnDefinition Width="{x:Static r:UIParameters.VerticalScrollBarWidthGridLength}"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <!-- NOTE: なぜがAutoだと下の行まで高さがおかしくなる(指定サイズ以上になる)ため、明示的に高さを指定する -->
            <RowDefinition Height="{x:Static r:UIParameters.HorizontalScrollBarWidthGridLength}"/>
            <RowDefinition Height="{x:Static r:UIParameters.TimeLocatorTimeBarHeightGridLength}"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition />
        </Grid.RowDefinitions>

        <!-- NOTE: サイズ計測用 -->
        <Rectangle Grid.Row="2" Grid.Column="0" x:Name="HeightMeasurementHeader" Fill="Transparent" IsHitTestVisible="False" Visibility="Hidden"/>
        <Rectangle Grid.Row="3" Grid.Column="0" x:Name="WidthMeasurementLayerControlArea" Fill="Transparent" IsHitTestVisible="False" Visibility="Hidden"/>

        <Grid Grid.Row="0" Grid.Column="0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,5,0">
                <CheckBox IsChecked="{Binding IsEnableShy}" Style="{StaticResource ShyCheckBox}" Command="{Binding ChangeEnableShyCommand}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_IsEnableShy}"/>
                <CheckBox IsChecked="{Binding IsEnableFrameBlend}" Style="{StaticResource FrameBlendCheckBox}" Margin="5,0,0,0" Command="{Binding ChangeEnableFrameBlendCommand}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_IsEnableFrameBlend}"/>
                <CheckBox IsChecked="{Binding IsEnableMotionBlur}" Style="{StaticResource MotionBlurCheckBox}" Margin="5,0,0,0" Command="{Binding ChangeEnableMotionBlurCommand}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_IsEnableMotionBlur}"/>
            </StackPanel>
        </Grid>

        <pr:ItemResizableStackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,2,0" Background="Transparent">
            <StackPanel Style="{StaticResource HeaderIconPanel}" Visibility="{Binding IsAVSwitchColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}" pr:ItemResizableStackPanel.ItemSize="69" pr:ItemResizableStackPanel.IsLocked="True">
                <Grid Style="{StaticResource IconContainer}" Margin="3,0,0,0" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_IsEnableVideo}">
                    <Path Data="{gm:FontawesomeResource ResourceKey=Eye}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
                <Grid Style="{StaticResource IconContainer}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_IsEnableAudio}">
                    <Path Data="{gm:FontawesomeResource ResourceKey=VolumeHigh}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
                <Grid Style="{StaticResource IconContainer}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_IsEnableSolo}">
                    <Path Data="{gm:FontawesomeResource ResourceKey=Circle}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
                <Grid Style="{StaticResource IconContainer}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_IsLock}">
                    <Path Data="{gm:FontawesomeResource ResourceKey=Lock}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
            </StackPanel>

            <Grid pr:ItemResizableStackPanel.ItemSize="{x:Static r:UIParameters.ArrowWidth}" pr:ItemResizableStackPanel.IsLocked="True"/>

            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsTagColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_LayerTagColor}" pr:ItemResizableStackPanel.ItemSize="{x:Static r:UIParameters.TagAreaWidth}" pr:ItemResizableStackPanel.IsLocked="True">
                <Path Data="{gm:FontawesomeResource ResourceKey=Tag}" Style="{StaticResource HeaderIconPath}"/>
            </Grid>

            <TextBlock Text="#"
                       Style="{StaticResource HeaderTextBlock}"
                       Visibility="{Binding IsLayerNumberColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                       ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_LayerNumber}"
                       pr:ItemResizableStackPanel.ItemMinSize="21"
                       pr:ItemResizableStackPanel.ItemSize="{Binding LayerNumberColumnWidth}"/>

            <TextBlock Text="{gm:LanguageResource ResourceKey=Timeline_LayerNameColumn}" Style="{StaticResource HeaderTextBlock}" pr:ItemResizableStackPanel.ItemMinSize="55" pr:ItemResizableStackPanel.ItemSize="{Binding LayerNameColumnWidth}"/>

            <TextBlock Text="{gm:LanguageResource ResourceKey=Timeline_LayerCommentColumn}" Style="{StaticResource HeaderTextBlock}" Visibility="{Binding IsLayerCommentColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}" pr:ItemResizableStackPanel.ItemMinSize="53" pr:ItemResizableStackPanel.ItemSize="{Binding LayerCommentColumnWidth}"/>

            <StackPanel Style="{StaticResource HeaderIconPanel}" Visibility="{Binding IsLayerSwitchColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}" pr:ItemResizableStackPanel.ItemMinSize="133" pr:ItemResizableStackPanel.ItemSize="{Binding LayerSwitchColumnWidth}">
                <Grid Style="{StaticResource IconContainer}" Margin="3,0,0,0" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_LayerSwitch_IsEnableShy}">
                    <Path Data="{StaticResource ShyIcon}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
                <Grid Style="{StaticResource IconContainer}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_LayerSwitch_IsEnableCollapse}">
                    <Path Data="{gm:FontawesomeResource ResourceKey=Sun}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
                <Grid Style="{StaticResource IconContainer}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_LayerSwitch_InterpolationQuality}">
                    <Path Data="{StaticResource ImageInterpolationLevel1Icon}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
                <Grid Style="{StaticResource IconContainer}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_LayerSwitch_IsEnableEffect}">
                    <Path Data="{gm:FontawesomeResource ResourceKey=FlorinSign}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
                <Grid Style="{StaticResource IconContainer}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_LayerSwitch_IsEnableFrameBlend}">
                    <Path Data="{StaticResource FrameBlendIcon}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
                <Grid Style="{StaticResource IconContainer}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_LayerSwitch_IsEnableMotionBlur}">
                    <Path Data="{StaticResource MotionBlurIcon}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
                <Grid Style="{StaticResource IconContainer}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_LayerSwitch_IsEnableAdjustmentLayer}">
                    <Path Data="{gm:FontawesomeResource ResourceKey=CircleHalfStroke}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
                <Grid Style="{StaticResource IconContainer}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_LayerSwitch_IsEnable3D}">
                    <Path Data="{gm:FontawesomeResource ResourceKey=Cube}" Style="{StaticResource HeaderIconPath}"/>
                </Grid>
            </StackPanel>

            <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="2,0" Visibility="{Binding IsModeColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}" pr:ItemResizableStackPanel.ItemMinSize="50" pr:ItemResizableStackPanel.ItemSize="{Binding ModeColumnWidth}">
                <TextBlock Text="{gm:LanguageResource ResourceKey=Timeline_ModeColumn}" Style="{StaticResource HeaderTextBlock}"/>
            </Grid>

            <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="2,0" Visibility="{Binding IsTrackMatteColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}" pr:ItemResizableStackPanel.ItemMinSize="75" pr:ItemResizableStackPanel.ItemSize="{Binding TrackMatteColumnWidth}">
                <TextBlock Text="{gm:LanguageResource ResourceKey=Timeline_TrackMatteColumn}" Style="{StaticResource HeaderTextBlock}"/>
            </Grid>

            <TextBlock Text="{gm:LanguageResource ResourceKey=Timeline_ParentLayerColumn}" Style="{StaticResource HeaderTextBlock}" Visibility="{Binding IsParentLayerColumnVisible, Converter={StaticResource BooleanToVisibilityConverter}}" pr:ItemResizableStackPanel.ItemMinSize="50" pr:ItemResizableStackPanel.ItemSize="{Binding ParentLayerColumnWidth}"/>

            <pr:ItemResizableStackPanel.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_AVSwitchColumn}" IsCheckable="True" IsChecked="{Binding IsAVSwitchColumnVisible}"/>
                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_TagColumn}" IsCheckable="True" IsChecked="{Binding IsTagColumnVisible}"/>
                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_LayerNumberColumn}" IsCheckable="True" IsChecked="{Binding IsLayerNumberColumnVisible}"/>
                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_LayerCommentColumn}" IsCheckable="True" IsChecked="{Binding IsLayerCommentColumnVisible}"/>
                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_LayerSwitchColumn}" IsCheckable="True" IsChecked="{Binding IsLayerSwitchColumnVisible}"/>
                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ModeColumn}" IsCheckable="True" IsChecked="{Binding IsModeColumnVisible}"/>
                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_TrackMatteColumn}" IsCheckable="True" IsChecked="{Binding IsTrackMatteColumnVisible}"/>
                    <MenuItem Header="{gm:LanguageResource ResourceKey=Timeline_ParentLayerColumn}" IsCheckable="True" IsChecked="{Binding IsParentLayerColumnVisible}"/>
                </ContextMenu>
            </pr:ItemResizableStackPanel.ContextMenu>
        </pr:ItemResizableStackPanel>

        <pt:WorkareaBar Grid.Row="2"
                        Grid.Column="1"
                        Grid.RowSpan="2"
                        BarHeight="{Binding ElementName=HeightMeasurementHeader, Path=ActualHeight}"
                        Duration="{Binding Duration}"
                        FrameRate="{Binding FrameRate}"
                        Range="{Binding TimeBarRange}"
                        RangeStart="{Binding TimeBarRangeStart}"
                        WorkareaBegin="{Binding WorkareaBegin}"
                        WorkareaEnd="{Binding WorkareaEnd}"
                        Command="{Binding ChangeWorkareaCommand}"
                        ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_WorkareaBar}"/>
        <pt:MarkerCollectionView Grid.Row="2"
                                 Grid.Column="1"
                                 CompositionMarkers="{Binding CompositionMarkers}"
                                 FrameRate="{Binding FrameRate}"
                                 Range="{Binding TimeBarRange}"
                                 RangeStart="{Binding TimeBarRangeStart}"
                                 AddMarkerCommand="{Binding AddMarkerCommand}"
                                 DeleteMarkerCommand="{Binding DeleteMarkerCommand}"
                                 MarkerMoveRequest="CompositionMarkerCollectionView_MarkerMoveRequest"/>

        <pt:LayerCollectionView x:Name="LayerCollectionView"
                                Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                ItemsSource="{Binding Layers}"
                                ControlAreaWidth="{Binding ElementName=WidthMeasurementLayerControlArea, Path=ActualWidth}"
                                CompositionFrameRate="{Binding FrameRate}"
                                Range="{Binding TimeBarRange}"
                                RangeStart="{Binding TimeBarRangeStart}"
                                SelectedItems="{Binding SelectedLayers}"
                                IsEnableShy="{Binding IsEnableShy}"
                                Style="{StaticResource LayerCollectionStyle}"
                                MouseDown="LayerCollectionView_MouseDown"
                                FocusManager.IsFocusScope="True"
                                dd:DragDrop.DropHandler="{Binding}"
                                dd:DragDrop.DragHandler="{Binding RelativeSource={RelativeSource Self}}"
                                dd:DragDrop.IsDragSource="True"
                                dd:DragDrop.IsDropTarget="True"/>

        <!-- NOTE: インジケーターを最前面に表示するため、TimeLocatorViewのXAMLの記述は下にする -->
        <pt:TimeLocatorView x:Name="TimeLocator"
                            Grid.Row="1"
                            Grid.Column="1"
                            Grid.RowSpan="3"
                            ShowIndicatorLineInRangeBar="True"
                            Duration="{Binding Duration}"
                            FrameRate="{Binding FrameRate}"
                            CurrentTime="{Binding CurrentTime}"
                            Range="{Binding TimeBarRange}"
                            RangeStart="{Binding TimeBarRangeStart}"
                            RangeScrollBarVisibility="Collapsed"
                            CompositionId="{Binding CompositionId}"
                            CurrentTimeChangeByUser="TimeLocator_CurrentTimeChangeByUser"/>
        <r:ReadOnlyPropertyWire Reciever="{Binding ElementName=TimeLocator, Path=IsScrubbing}" Sender="{Binding IsScrubbing}"/>

        <!-- NOTE: MinimumRangeの計算の都合上、TimeLocatorViewよりも下に置く -->
        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <pt:TimeScaleSlider Grid.Column="0" Width="100" Value="{Binding TimeBarRange, Converter={StaticResource TimeToDoubleConverter}}" Minimum="{Binding ElementName=TimeLocator, Path=MinimumRange, Converter={StaticResource TimeToDoubleConverter}}" Maximum="{Binding Duration, Converter={StaticResource TimeToDoubleConverter}}"/>
            <pr:RangeScrollBar Grid.Column="1" Minimum="{x:Static uvo:Time.Zero}" Maximum="{Binding Duration}" Range="{Binding TimeBarRange}" RangeStart="{Binding TimeBarRangeStart}" MinimumRange="{Binding ElementName=TimeLocator, Path=MinimumRange, Mode=OneWay}" ToolTip="{gm:LanguageResource ResourceKey=Timeline_ToolTip_RangeScrollBar}"/>
        </Grid>
    </Grid>

    <i:Interaction.Behaviors>
        <b:TiltWheelBehavior MouseTiltWheel="TiltWheelBehavior_MouseTiltWheel"/>
    </i:Interaction.Behaviors>
</UserControl>
