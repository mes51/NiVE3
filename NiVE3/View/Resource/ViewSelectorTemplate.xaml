<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:v="clr-namespace:NiVE3.View.Pane"
                    xmlns:vm="clr-namespace:NiVE3.ViewModel">
    <DataTemplate DataType="{x:Type vm:FootageListViewModel}">
        <v:FootageListView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PreviewViewModel}">
        <v:PreviewView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:TimelineViewModel}">
        <v:TimelineView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:EffectListViewModel}">
        <v:EffectListView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PlayControllerViewModel}">
        <v:PlayControllerView />
    </DataTemplate>
</ResourceDictionary>