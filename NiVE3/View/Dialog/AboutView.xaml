<UserControl x:Class="NiVE3.View.Dialog.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NiVE3.View.Dialog"
             xmlns:gm="clr-namespace:NiVE3.View.Resource.Wpf.GeneratedMarkup"
             xmlns:pr="http://prismlibrary.com/"
             mc:Ignorable="d" 
             pr:ViewModelLocator.AutoWireViewModel="True"
             d:DesignWidth="500"
             d:DesignHeight="357">
    <pr:Dialog.WindowStyle>
        <Style TargetType="{x:Type Window}">
            <Setter Property="pr:Dialog.WindowStartupLocation" Value="CenterOwner"/>
            <Setter Property="ResizeMode" Value="NoResize"/>
            <Setter Property="Width" Value="500"/>
            <Setter Property="Height" Value="395"/> <!-- DesignHeight + 38 -->
            <Setter Property="ShowInTaskbar" Value="False"/>
        </Style>
    </pr:Dialog.WindowStyle>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition />
        </Grid.RowDefinitions>

        <Image Grid.Row="0" Source="/Resources/Logo.png" Height="237"/>

        <Grid Grid.Row="1" Margin="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="NicoVisualEffects ver"/>
                    <TextBlock Text="{Binding VersionString}" Margin="5,0,0,0"/>
                </StackPanel>

                <TextBlock Text="ライセンスは LICENCE.txt、および License ディレクトリをご確認ください" Margin="0,20,0,0"/>
            </StackPanel>

            <Button Content="{gm:LanguageResource ResourceKey=Dialog_OK}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Command="{Binding CloseCommand}"/>
        </Grid>
    </Grid>
</UserControl>
