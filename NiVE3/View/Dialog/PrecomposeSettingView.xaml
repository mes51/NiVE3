<UserControl x:Class="NiVE3.View.Dialog.PrecomposeSettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NiVE3.View.Dialog"
             xmlns:pr="http://prismlibrary.com/"
             xmlns:cv="clr-namespace:NiVE3.View.Converter"
             xmlns:vl="clr-namespace:NiVE3.View.Validation"
             xmlns:vm="clr-namespace:NiVE3.ViewModel.Dialog"
             xmlns:gm="clr-namespace:NiVE3.View.Resource.Wpf.GeneratedMarkup"
             mc:Ignorable="d" 
             x:Name="Root"
             Width="450"
             d:DesignHeight="450">
    <UserControl.Resources>
        <Thickness x:Key="ItemMargin">0,0,0,5</Thickness>
        <cv:EnumToBoolConverter x:Key="EnumToBoolConverter"/>

        <Style x:Key="CopyParentCheckBoxStyle" TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="IsEnabled" Value="False"/>

            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasParent}" Value="True"/>
                        <Condition Binding="{Binding Mode}" Value="{x:Static vm:PrecomposeMode.MoveAll}"/>
                    </MultiDataTrigger.Conditions>

                    <Setter Property="IsEnabled" Value="True"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <pr:Dialog.WindowStyle>
        <Style TargetType="{x:Type Window}">
            <Setter Property="pr:Dialog.WindowStartupLocation" Value="CenterOwner"/>
            <Setter Property="SizeToContent" Value="WidthAndHeight"/>
            <Setter Property="Width" Value="450"/>
            <Setter Property="ResizeMode" Value="NoResize"/>
            <Setter Property="ShowInTaskbar" Value="False"/>
        </Style>
    </pr:Dialog.WindowStyle>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{gm:LanguageResource ResourceKey=PrecomposeSettingView_NewCompositionName_Label}" Margin="0,0,5,0"/>
            <TextBox x:Name="NewCompositionNameTextBox" Grid.Column="1">
                <TextBox.Text>
                    <Binding Path="NewCompositionName" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <vl:StringLengthValidationRule MinLength="1"/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>
        </Grid>

        <StackPanel Grid.Row="1" Margin="{StaticResource ItemMargin}">
            <RadioButton Content="{gm:LanguageResource ResourceKey=PrecomposeSettingView_Mode_LeaveAll}" Margin="{StaticResource ItemMargin}" IsChecked="{Binding Mode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:PrecomposeMode.LeaveAll}}" IsEnabled="{Binding TargetIsSingleLayer}"/>
            <RadioButton Content="{gm:LanguageResource ResourceKey=PrecomposeSettingView_Mode_MoveAll}" Margin="{StaticResource ItemMargin}" IsChecked="{Binding Mode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:PrecomposeMode.MoveAll}}"/>
        </StackPanel>

        <GroupBox Grid.Row="2" Margin="0,0,0,10" Header="コピー設定">
            <StackPanel Margin="10">
                <CheckBox Content="{gm:LanguageResource ResourceKey=PrecomposeSettingView_AlignDurationToLayer}" Margin="{StaticResource ItemMargin}" IsChecked="{Binding AlignDurationToLayer}" IsEnabled="{Binding Mode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:PrecomposeMode.MoveAll}}"/>
                <CheckBox Content="{gm:LanguageResource ResourceKey=PrecomposeSettingView_CopyParent}" IsChecked="{Binding CopyParent}" Style="{StaticResource CopyParentCheckBoxStyle}"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Margin="0,0,10,0" Content="{gm:LanguageResource ResourceKey=Dialog_Cancel}" Style="{StaticResource DialogDefaultCancelButton}" Command="{Binding CancelCommand}"/>
            <Button Content="{gm:LanguageResource ResourceKey=Dialog_OK}" Command="{Binding OKCommand}">
                <Button.Style>
                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource DialogOKButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=NewCompositionNameTextBox, Path=(Validation.HasError)}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
