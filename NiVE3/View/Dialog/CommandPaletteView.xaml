<UserControl x:Class="NiVE3.View.Dialog.CommandPaletteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NiVE3.View.Dialog"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:pr="http://prismlibrary.com/"
             xmlns:prv="clr-namespace:NiVE3.View.Primitive"
             xmlns:gm="clr-namespace:NiVE3.View.Resource.Wpf.GeneratedMarkup"
             xmlns:ugm="clr-namespace:NiVE3.UI.Resources.Wpf.GeneratedMarkup;assembly=NiVE3.UI"
             pr:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             Loaded="Root_Loaded"
             d:DesignHeight="450" d:DesignWidth="800">
    <pr:Dialog.WindowStyle>
        <Style TargetType="{x:Type Window}">
            <Setter Property="pr:Dialog.WindowStartupLocation" Value="CenterOwner"/>
            <Setter Property="WindowStyle" Value="None"/>
            <Setter Property="Height" Value="500"/>
            <Setter Property="Width" Value="500"/>
            <Setter Property="ResizeMode" Value="NoResize"/>
            <Setter Property="ShowInTaskbar" Value="False"/>
        </Style>
    </pr:Dialog.WindowStyle>
    <UserControl.Resources>
        <DataTemplate x:Key="CommandTemplate" DataType="{x:Type sys:Tuple`5}">
            <TextBlock Text="{Binding Item1}"/>
        </DataTemplate>

        <Style x:Key="CommandItemContainerStyle" TargetType="{x:Type ListViewItem}">
            <Setter Property="IsEnabled" Value="{Binding Item5}"/>
        </Style>
    </UserControl.Resources>
    <Border BorderBrush="{ugm:AppearanceResource ResourceKey=PopupWindowBorderBrush}" BorderThickness="1">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition />
            </Grid.RowDefinitions>

            <prv:PlaceholderTextBox x:Name="FilterTextBox" Grid.Row="0" FontSize="28" Margin="0,0,0,10" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Placeholder="{gm:LanguageResource ResourceKey=CommandPalettePopup_FilterText_Placeholder}" PlaceholderFontSize="20" KeyDown="FilterTextBox_KeyDown"/>
            <ListView Grid.Row="1"
                      FontSize="16"
                      ItemTemplate="{StaticResource CommandTemplate}"
                      ItemContainerStyle="{StaticResource CommandItemContainerStyle}"
                      ItemsSource="{Binding FilteredCommands}"
                      SelectedItem="{Binding SelectedCommand}"
                      VirtualizingPanel.IsVirtualizing="True"
                      MouseDoubleClick="CommandListView_MouseDoubleClick"
                      KeyDown="CommandListView_KeyDown"/>
        </Grid>
    </Border>
</UserControl>
