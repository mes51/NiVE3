<UserControl x:Class="NiVE3.View.Dialog.GenerateAudioLevelValueKeyFrameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NiVE3.View.Dialog"
             xmlns:pr="http://prismlibrary.com/"
             xmlns:upr="clr-namespace:NiVE3.UI.Primitive;assembly=NiVE3.UI"
             xmlns:cv="clr-namespace:NiVE3.View.Converter"
             xmlns:m="clr-namespace:NiVE3.Model"
             xmlns:gm="clr-namespace:NiVE3.View.Resource.Wpf.GeneratedMarkup"
             mc:Ignorable="d" 
             pr:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="450" d:DesignWidth="300">
    <pr:Dialog.WindowStyle>
        <Style TargetType="{x:Type Window}">
            <Setter Property="pr:Dialog.WindowStartupLocation" Value="CenterOwner"/>
            <Setter Property="Width" Value="300"/>
            <Setter Property="SizeToContent" Value="Height"/>
            <Setter Property="ResizeMode" Value="NoResize"/>
            <Setter Property="ShowInTaskbar" Value="False"/>
        </Style>
    </pr:Dialog.WindowStyle>
    <UserControl.Resources>
        <cv:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
    </UserControl.Resources>
    <StackPanel Margin="10">
        <TextBlock Text="{gm:LanguageResource ResourceKey=GenerateAudioLevelValueKeyFrame_Type}"/>
        
        <UniformGrid Columns="3" Margin="0,5,0,0">
            <RadioButton Content="{gm:LanguageResource ResourceKey=GenerateAudioLevelValueKeyFrame_Type_Average}" IsChecked="{Binding Type, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static m:AudioLevelValueType.Average}}"/>
            <RadioButton Content="{gm:LanguageResource ResourceKey=GenerateAudioLevelValueKeyFrame_Type_Max}" IsChecked="{Binding Type, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static m:AudioLevelValueType.Max}}"/>
            <RadioButton Content="{gm:LanguageResource ResourceKey=GenerateAudioLevelValueKeyFrame_Type_Min}" IsChecked="{Binding Type, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static m:AudioLevelValueType.Min}}"/>
        </UniformGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{gm:LanguageResource ResourceKey=Dialog_Cancel}" Style="{StaticResource DialogCancelButton}" Command="{Binding CancelCommand}" Margin="0,0,5,0"/>
            <Button Content="{gm:LanguageResource ResourceKey=Dialog_OK}" Style="{StaticResource DialogDefaultOKButton}" Command="{Binding OKCommand}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
