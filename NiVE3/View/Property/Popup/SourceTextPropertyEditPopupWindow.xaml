<Window x:Class="NiVE3.View.Property.Popup.SourceTextPropertyEditPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NiVE3.View.Property.Popup"
        xmlns:pr="http://prismlibrary.com/"
        xmlns:gm="clr-namespace:NiVE3.View.Resource.Wpf.GeneratedMarkup"
        mc:Ignorable="d"
        x:Name="RootWindow"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        MinWidth="200"
        MinHeight="100"
        Deactivated="RootWindow_Deactivated">
    <Border Background="White" BorderBrush="DarkGray" BorderThickness="1">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0" Text="{Binding ElementName=RootWindow, Path=SourceText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" AcceptsTab="True" PreviewKeyDown="TextBox_PreviewKeyDown"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{gm:LanguageResource ResourceKey=Dialog_Cancel}" Margin="0,5,5,0" Style="{StaticResource DialogDefaultCancelButton}" Command="{Binding ElementName=RootWindow, Path=CancelCommand}"/>
                <Button Content="{gm:LanguageResource ResourceKey=Dialog_OK}" Margin="0,5,0,0" Style="{StaticResource DialogOKButton}" Command="{Binding ElementName=RootWindow, Path=OKCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
