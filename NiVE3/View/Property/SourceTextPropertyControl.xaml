<plc:PropertyControlBase x:Class="NiVE3.View.Property.SourceTextPropertyControl"
                         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                         xmlns:local="clr-namespace:NiVE3.View.Property"
                         xmlns:plc="clr-namespace:NiVE3.Plugin.Property.Control;assembly=NiVE3.Plugin"
                         xmlns:ucv="clr-namespace:NiVE3.UI.Converter;assembly=NiVE3.UI"
                         xmlns:gm="clr-namespace:NiVE3.View.Resource.Wpf.GeneratedMarkup"
                         mc:Ignorable="d" 
                         x:Name="Root"
                         d:DesignHeight="450" d:DesignWidth="800">
    <plc:PropertyControlBase.Resources>
        <ucv:BooleanInvertConverter x:Key="BooleanInvertConverter"/>
    </plc:PropertyControlBase.Resources>
    <Grid>
        <Button x:Name="EditButton" Content="{gm:LanguageResource ResourceKey=SourceTextPropertyControl_Edit}" Width="Auto" HorizontalAlignment="Left" IsEnabled="{Binding ParentLayerIsLock, Converter={StaticResource BooleanInvertConverter}}" Command="{Binding ElementName=Root, Path=OpenDialogCommand}"/>
    </Grid>
</plc:PropertyControlBase>
